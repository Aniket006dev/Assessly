PORT=5000
NODE_ENV=development

# MongoDB — use 127.0.0.1 NOT localhost (avoids IPv6 issues on Windows/Node 18+)
MONGODB_URI=mongodb://127.0.0.1:27017/vedaai

# OR use MongoDB Atlas (cloud, no local install needed):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vedaai

# JWT
JWT_SECRET=vedaai_super_secret_jwt_key_change_in_production

# Redis (optional — app works without it)
REDIS_URL=redis://127.0.0.1:6379

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173


